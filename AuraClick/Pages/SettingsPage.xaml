<?xml version="1.0" encoding="utf-8" ?>

<Page
    x:Class="AuraClick.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:WinUI3Localizer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    x:DefaultBindMode="TwoWay"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Thickness x:Key="HyperlinkButtonNegativeMargin">-12,0,0,0</Thickness>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="1,20,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Margin="{StaticResource ContentMargin}">
            <StackPanel Spacing="{StaticResource SettingsCardSpacing}">

                <win:StackPanel.ChildrenTransitions>
                    <win:EntranceThemeTransition FromVerticalOffset="50" />
                    <win:RepositionThemeTransition IsStaggeringEnabled="False" />
                </win:StackPanel.ChildrenTransitions>

                <TextBlock l:Uids.Uid="SettingsSubtitleTextBlock" Style="{StaticResource SubtitleTextBlockStyle}" />

                <TextBlock l:Uids.Uid="AppearanceSettingsSectionHeaderTextBlock" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <!--  Language  -->
                <controls:SettingsCard l:Uids.Uid="SettingsCardLanguage" HeaderIcon="{ui:FontIcon Glyph=&#xF2B7;}">
                    <ComboBox
                        x:Name="LanguageComboBox"
                        ItemsSource="{x:Bind LanguageDisplayNames, Mode=OneWay}"
                        SelectedIndex="{x:Bind LanguageSelectedIndex}" />
                </controls:SettingsCard>

                <!--  App theme  -->
                <controls:SettingsCard l:Uids.Uid="SettingsCardAppTheme" HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ThemeComboBox" SelectedIndex="{x:Bind ThemeSelectedIndex}">
                        <ComboBoxItem l:Uids.Uid="ComboBoxItemAppThemeSystem" />
                        <ComboBoxItem l:Uids.Uid="ComboBoxItemAppThemeLight" />
                        <ComboBoxItem l:Uids.Uid="ComboBoxItemAppThemeDark" />
                    </ComboBox>
                </controls:SettingsCard>

                <!--  Backdrop material  -->
                <controls:SettingsCard l:Uids.Uid="SettingsCardBackdropMaterial" HeaderIcon="{ui:FontIcon Glyph=&#xEF1F;}">
                    <ComboBox x:Name="BackdropComboBox" SelectedIndex="{x:Bind BackdropSelectedIndex}">
                        <ComboBoxItem l:Uids.Uid="ComboBoxItemBackdropMaterialMica" />
                        <ComboBoxItem l:Uids.Uid="ComboBoxItemBackdropMaterialMicaAlt" />
                        <ComboBoxItem l:Uids.Uid="ComboBoxItemBackdropMaterialAcrylic" />
                    </ComboBox>
                </controls:SettingsCard>

                <TextBlock l:Uids.Uid="TextBlockBehavior" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <!--  Always on top  -->
                <controls:SettingsCard l:Uids.Uid="SettingsCardAlwaysOnTop" HeaderIcon="{ui:FontIcon Glyph=&#xE7C4;}">
                    <ToggleSwitch IsOn="{x:Bind IsAlwaysOnTop}" />
                </controls:SettingsCard>

                <!--  Notification badge  -->
                <controls:SettingsExpander l:Uids.Uid="SettingsExpanderNotificationBadge" HeaderIcon="{ui:FontIcon Glyph=&#xEDAD;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Left">
                            <CheckBox l:Uids.Uid="CheckBoxNotificationBadgePlaying" IsChecked="{x:Bind NotificationBadgePlaying}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard ContentAlignment="Left">
                            <CheckBox l:Uids.Uid="CheckBoxNotificationBadgePaused" IsChecked="{x:Bind NotificationBadgePaused}" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <TextBlock l:Uids.Uid="TextBlockAbout" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <!--  App version  -->
                <controls:SettingsExpander
                    x:Name="AppAboutSettingsExpander"
                    Description="Copyright © 2026 Ryan Luu"
                    HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/StoreLogo.png}">
                    <TextBlock
                        x:Name="AppVersionTextBlock"
                        win:IsTextSelectionEnabled="True"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <controls:SettingsExpander.Items>

                        <!--  Terms  -->
                        <controls:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                            <StackPanel>
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    l:Uids.Uid="HyperlinkButtonPrivacyPolicy"
                                    NavigateUri="https://github.com/ryanlua/auraclick/blob/HEAD/PRIVACY_POLICY.md" />
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    l:Uids.Uid="HyperlinkButtonLicense"
                                    NavigateUri="https://github.com/ryanlua/auraclick/blob/HEAD/COPYING.md" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <!--  Related links  -->
                        <controls:SettingsCard
                            HorizontalContentAlignment="Left"
                            l:Uids.Uid="SettingsCardRelatedLinks"
                            ContentAlignment="Vertical">
                            <StackPanel>
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    l:Uids.Uid="HyperlinkButtonTranslate"
                                    NavigateUri="https://crowdin.com/project/auraclick" />
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    l:Uids.Uid="HyperlinkButtonSource"
                                    NavigateUri="https://github.com/ryanlua/auraclick" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <!--  Dependencies  -->
                        <controls:SettingsCard
                            HorizontalContentAlignment="Left"
                            l:Uids.Uid="SettingsCardDependencies"
                            ContentAlignment="Vertical">
                            <StackPanel>
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    Content="Windows App SDK"
                                    NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    Content="Windows Community Toolkit"
                                    NavigateUri="https://github.com/CommunityToolkit/Windows" />
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    Content="CsWin32"
                                    NavigateUri="https://github.com/Microsoft/CsWin32" />
                                <HyperlinkButton
                                    Margin="{StaticResource HyperlinkButtonNegativeMargin}"
                                    Content="DevWinUI"
                                    NavigateUri="https://github.com/ghost1372/DevWinUI" />
                            </StackPanel>
                        </controls:SettingsCard>

                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>